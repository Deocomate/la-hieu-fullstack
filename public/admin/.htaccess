<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # /admin is both the Filament panel path and the published asset folder.
    # Directory requests must go to Laravel; concrete asset files remain public.
    RewriteRule ^$ ../index.php [L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^.*$ ../index.php [L]
</IfModule>
